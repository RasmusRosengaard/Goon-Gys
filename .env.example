# Copy to .env and fill in. Never commit .env.
# No API keys are needed: story/sidecar text is generated by the Claude Code CLI
# (`claude -p`, same login as interactive use), and the default voice (edge-tts)
# is free and keyless.

# --- Story: Reddit (Stage 1, source=reddit/hybrid) ---
# Keyless: we scrape the public RSS feeds (the .json API is 403-blocked). Reddit only
# serves these to a browser-like client, so the code defaults to a Chrome User-Agent.
# Override here only if you want a custom one (a bare "MyApp/0.1" UA gets blocked).
# REDDIT_USER_AGENT=

# --- Defaults ---
DEFAULT_VOICE=en-US-GuyNeural
DEFAULT_BACKGROUND_CATEGORY=minecraft_bhop
